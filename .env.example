# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Inngest
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=your-signing-key

# Meta WhatsApp / Facebook Login (Embedded Signup)
# HTTPS required for FB.login — local dev: npm run dev:https → https://localhost:3000
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_WEBHOOK_VERIFY_TOKEN=your-random-verify-token
# Facebook Login → Configurations → Embedded Signup (Login Configuration → config ID)
META_EMBEDDED_SIGNUP_CONFIG_ID=your-login-config-id

# Security — must be exactly 64 hex chars (generate: openssl rand -hex 32)
ENCRYPTION_KEY=
ADMIN_SECRET=a-secret-for-admin-api-at-least-16-chars

# Cal.com (optional — per-org credentials are stored in DB, this is only for overriding the base URL in tests)
CAL_COM_API_BASE_URL=https://api.cal.com

# Sentry (optional)
SENTRY_DSN=

# App URL — use https in dev when testing WhatsApp Embedded Signup
NEXT_PUBLIC_APP_URL=https://localhost:3000
