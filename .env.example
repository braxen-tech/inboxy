# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (KB document embeddings + RAG retrieval)
VOYAGE_API_KEY=

# Inngest — required for message processing and KB ingest (Manage → Event keys / Signing keys):
# - Event key: used by EventBus → inngest.send() → POST https://inn.gs/e/<key>
# - Signing key: used by Inngest to call /api/inngest (starts with signkey-prod-)
# Local dev: run `npm run dev:inngest` (terminal 1) + `npm run inngest:dev` (terminal 2)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Security — must be exactly 64 hex chars (generate: openssl rand -hex 32)
ENCRYPTION_KEY=
ADMIN_SECRET=a-secret-for-admin-api-at-least-16-chars

# Cal.com (optional — per-org credentials are stored in DB, this is only for overriding the base URL in tests)
CAL_COM_API_BASE_URL=https://api.cal.com

# PostHog (Inboxy org — project 458321)
NEXT_PUBLIC_POSTHOG_KEY=phc_zabN75HGtXzHsSbsxrawCcwKKgxcBtztVrDCdJLdPtdV
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Labels prod vs staging in logs, traces, and analytics (set per Vercel environment)
# production | staging | development | preview
NEXT_PUBLIC_DEPLOYMENT_ENV=development
DEPLOYMENT_ENV=development

# App URL — auth email redirects, webhooks, invite links
# Local: http://localhost:3000 | Production: https://inboxy.braxentech.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (invites + optional notification emails)
# Create API key at https://resend.com — verify a sending domain before production
RESEND_API_KEY=
# Must use a verified domain in Resend (e.g. Inboxy <noreply@yourdomain.com>)
RESEND_FROM_EMAIL=Inboxy <noreply@braxentech.com>

# Stripe Billing (Inboxy platform subscriptions — separate from per-org Stripe Connect)
STRIPE_BILLING_SECRET_KEY=sk_test_...
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...
# Trial days on all plans (card required at signup via Checkout)
STRIPE_TRIAL_DAYS=14
# Optional: override price IDs if not using the default sandbox prices
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PROFESSIONAL=price_...
# STRIPE_PRICE_BUSINESS=price_...

# Pilot mode — free access with Business plan (subscription_id=pilot in DB)
# Set to true during pilot; remove or set false to force Stripe checkout
# INBOXY_PILOT_MODE=true

# Braxen contact (WhatsApp CTA on marketing pages; default matches braxen-web)
# NEXT_PUBLIC_BRAXEN_WHATSAPP_NUMBER=5521973118404

# Chatwoot live chat widget (marketing site)
NEXT_PUBLIC_CHATWOOT_BASE_URL=https://app.chatwoot.com
NEXT_PUBLIC_CHATWOOT_WEBSITE_TOKEN=SjX6XmQZZDir34mA81fP4y8j
